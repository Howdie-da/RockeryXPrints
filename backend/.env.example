# Backend Environment Variables Template

# Server Port
PORT=1000

# MongoDB Database Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# Allowed CORS Origins (comma-separated for multiple origins, e.g. http://localhost:5173,http://localhost:3000)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT Access Token Configuration
ACCESS_TOKEN_SECRET=your_jwt_access_token_secret_here
ACCESS_TOKEN_EXPIRY=1d

# JWT Refresh Token Configuration
REFRESH_TOKEN_SECRET=your_jwt_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
